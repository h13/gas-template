{
  "name": "gas-template",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run clean && pnpm run bundle && cp appsscript.json dist/appsscript.json && cp src/*.html dist/",
    "lint": "eslint --fix src/ test/",
    "lint:css": "stylelint '**/*.{css,scss,html}'",
    "lint:html": "htmlhint --ignore 'coverage/**,dist/**' '**/*.html'",
    "format": "prettier --write .",
    "test": "jest test/ --passWithNoTests --detectOpenHandles --coverage",
    "clean": "rimraf build dist",
    "typecheck": "tsc --noEmit",
    "bundle": "rollup --no-treeshake -c rollup.config.mjs",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "deploy": "pnpm run check && pnpm run build && cp .clasp-dev.json .clasp.json && clasp push -f",
    "deploy:prod": "pnpm run check && pnpm run build && cp .clasp-prod.json .clasp.json && clasp push",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-perfectionist": "4.15.1",
    "htmlhint": "1.9.2",
    "prettier": "3.8.1",
    "stylelint": "17.4.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "@types/google-apps-script": "2.0.8",
    "@types/jest": "30.0.0",
    "eslint-plugin-prettier": "5.5.5",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "lint-staged": "16.3.3",
    "postcss-html": "1.8.1",
    "rimraf": "6.1.3",
    "rollup": "4.59.0",
    "rollup-plugin-cleanup": "3.2.1",
    "rollup-plugin-prettier": "4.1.2",
    "rollup-plugin-typescript2": "0.36.0",
    "ts-jest": "29.4.6"
  },
  "dependencies": {
    "@google/clasp": "3.2.0"
  },
  "pnpm": {
    "overrides": {
      "diff": ">=8.0.3"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
